{
  "manifest_version": 3,
  "name": "The Archaeologist – Steam Tracker",
  "short_name": "Archaeologist",
  "version": "1.0.0",
  "description": "Extrae historial de sesiones de Steam y lo sincroniza con tu Steam Tracker.",

  "permissions": ["storage", "activeTab", "scripting"],

  "host_permissions": [
    "https://steamcommunity.com/*",
    "https://*.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/id/*/games*",
        "https://steamcommunity.com/profiles/*/games*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "The Archaeologist"
  },

  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://steamcommunity.com/*"
      ]
    }
  ],

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
